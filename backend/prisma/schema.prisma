generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SELLER
  COLLECTOR
}

enum SaleStatus {
  ACTIVE
  PAID
  CANCELLED
}

enum InstallmentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  OTHER
}

enum BalanceAllocation {
  NEXT_INSTALLMENT
  REMAINING_INSTALLMENTS
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  role      UserRole  @default(SELLER)
  active    Boolean   @default(true)
  sales     Sale[]
  payments  Payment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  dni       String   @unique
  phone     String
  address   String?
  notes     String?
  sales     Sale[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Motorcycle {
  id            Int      @id @default(autoincrement())
  brand         String
  model         String
  year          Int?
  domain        String?  @unique
  chassisNumber String?  @unique
  engineNumber  String?  @unique
  color         String?
  sale          Sale?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Sale {
  id                      Int           @id @default(autoincrement())
  saleNumber              Int           @unique
  clientId                Int
  motorcycleId            Int           @unique
  sellerId                Int
  client                  Client        @relation(fields: [clientId], references: [id])
  motorcycle              Motorcycle    @relation(fields: [motorcycleId], references: [id])
  seller                  User          @relation(fields: [sellerId], references: [id])
  salePrice               Decimal       @db.Decimal(12, 2)
  downPayment             Decimal       @db.Decimal(12, 2)
  financedAmount          Decimal       @db.Decimal(12, 2)
  financingInterestRate   Decimal       @default(0) @db.Decimal(5, 2)
  financingInterestAmount Decimal       @default(0) @db.Decimal(12, 2)
  installmentPlan         Int
  installmentAmount       Decimal       @db.Decimal(12, 2)
  status                  SaleStatus    @default(ACTIVE)
  saleDate                DateTime      @default(now())
  installments            Installment[]
  saleReceipt             SaleReceipt?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  @@index([clientId])
  @@index([sellerId])
  @@index([saleDate])
}

model SaleReceipt {
  id            Int       @id @default(autoincrement())
  saleId        Int       @unique
  sale          Sale      @relation(fields: [saleId], references: [id])
  receiptNumber String    @unique
  printedAt     DateTime?
  createdAt     DateTime  @default(now())
}

model Installment {
  id        Int               @id @default(autoincrement())
  saleId    Int
  sale      Sale              @relation(fields: [saleId], references: [id])
  number    Int
  amount    Decimal           @db.Decimal(12, 2)
  dueDate   DateTime
  status    InstallmentStatus @default(PENDING)
  paidAt    DateTime?
  payment   Payment?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([saleId, number])
  @@index([dueDate])
  @@index([status])
}

model Payment {
  id                Int                @id @default(autoincrement())
  installmentId     Int                @unique
  userId            Int
  installment       Installment        @relation(fields: [installmentId], references: [id])
  user              User               @relation(fields: [userId], references: [id])
  amount            Decimal            @db.Decimal(12, 2)
  expectedAmount    Decimal            @default(0) @db.Decimal(12, 2)
  carriedBalance    Decimal            @default(0) @db.Decimal(12, 2)
  balanceAllocation BalanceAllocation?
  interestRate      Decimal            @default(0) @db.Decimal(5, 2)
  interestAmount    Decimal            @default(0) @db.Decimal(12, 2)
  method            PaymentMethod      @default(CASH)
  paidAt            DateTime           @default(now())
  notes             String?
  receipt           Receipt?
  createdAt         DateTime           @default(now())

  @@index([userId])
  @@index([paidAt])
}

model Receipt {
  id            Int       @id @default(autoincrement())
  paymentId     Int       @unique
  payment       Payment   @relation(fields: [paymentId], references: [id])
  receiptNumber String    @unique
  printedAt     DateTime?
  createdAt     DateTime  @default(now())
}
